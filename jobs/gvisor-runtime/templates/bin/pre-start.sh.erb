#!/bin/bash
set -eu

RUNSC_PKG=/var/vcap/packages/runsc
SHIM_PKG=/var/vcap/packages/containerd-shim-runsc-v1
CONFIG_DIR=/etc/containerd/runsc
LOG_DIR=<%= p('gvisor.log_dir') %>

# Install binaries to PATH visible by containerd
ln -sf ${RUNSC_PKG}/runsc /usr/local/bin/runsc
ln -sf ${SHIM_PKG}/containerd-shim-runsc-v1 /usr/local/bin/containerd-shim-runsc-v1

# Write runtime config
mkdir -p ${CONFIG_DIR}
cp /var/vcap/jobs/gvisor-runtime/config/runsc-config.toml ${CONFIG_DIR}/config.toml

# Ensure log directory exists
mkdir -p ${LOG_DIR}
chmod 777 ${LOG_DIR}

# Inject gVisor-required settings into garden's config.ini if not already present.
# Garden's BOSH job template doesn't support these properties natively, so we append them
# after the containerd-socket line. This must run AFTER garden's pre-start renders config.ini.
#
# Two settings are required:
#   1. containerd-runtime-type = io.containerd.runsc.v1
#      Routes container creation through the gVisor shim instead of runc.
#   2. use-containerd-for-processes = true
#      Routes Run() (exec into container) through containerd instead of the runtime-plugin (runc).
#      Without this, healthchecks fail with "container does not exist" because runc doesn't know
#      about containers created by runsc.
GARDEN_CONFIG=/var/vcap/jobs/garden/config/config.ini
if [ -f "${GARDEN_CONFIG}" ] && ! grep -q "containerd-runtime-type" "${GARDEN_CONFIG}"; then
  sed -i '/containerd-socket/a\  containerd-runtime-type = <%= p("gvisor.containerd_runtime_type") %>' "${GARDEN_CONFIG}"
  echo "Injected containerd-runtime-type into garden config.ini"
fi
if [ -f "${GARDEN_CONFIG}" ] && ! grep -q "use-containerd-for-processes" "${GARDEN_CONFIG}"; then
  sed -i '/containerd-runtime-type/a\  use-containerd-for-processes = true' "${GARDEN_CONFIG}"
  echo "Injected use-containerd-for-processes into garden config.ini"
fi

echo "gVisor runtime installed: $(runsc --version 2>&1 | head -1)"

# Fix exclude_image_from_quota for gVisor cells.
# Garden's template renders this as 'false' by default. gVisor cells MUST have 'true'
# because cflinuxfs4 rootfs (1.4GB) would otherwise count against container disk_quota,
# causing "disk limit is smaller than volume size" errors on container creation.
#
# Handle both cases:
#   - Property exists as 'false' → replace with 'true'
#   - Property missing entirely → inject after 'cleanup_threshold_in_megabytes' or at end
GROOTFS_CONFIG=/var/vcap/jobs/garden/config/grootfs_config.yml
if [ -f "${GROOTFS_CONFIG}" ]; then
  if grep -q "exclude_image_from_quota: false" "${GROOTFS_CONFIG}"; then
    sed -i 's/exclude_image_from_quota: false/exclude_image_from_quota: true/' "${GROOTFS_CONFIG}"
    echo "Fixed exclude_image_from_quota: false → true in grootfs_config.yml"
  elif ! grep -q "exclude_image_from_quota" "${GROOTFS_CONFIG}"; then
    echo "exclude_image_from_quota: true" >> "${GROOTFS_CONFIG}"
    echo "Injected exclude_image_from_quota: true into grootfs_config.yml"
  fi
fi
